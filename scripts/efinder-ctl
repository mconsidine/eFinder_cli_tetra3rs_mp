#!/usr/bin/env python3
"""
efinder-ctl: control and inspect a running eFinder daemon.

Usage:
  efinder-ctl status
  efinder-ctl version
  efinder-ctl ping

  efinder-ctl boresight show
  efinder-ctl boresight center
  efinder-ctl boresight set Y X

  efinder-ctl calibration status
  efinder-ctl calibration reset

  efinder-ctl exposure get
  efinder-ctl exposure set SECONDS [--persist]
  efinder-ctl gain set GAIN [--persist]

  efinder-ctl polar start
  efinder-ctl polar status
  efinder-ctl polar cancel
  efinder-ctl polar set-latitude DEGREES [--no-persist]

  efinder-ctl raw '{"cmd":"...","args":{...}}'

Talks to /run/efinder/maint.sock. You need to be a member of the
'efinder' group (or root) to use this. Add yourself with:
  sudo usermod -a -G efinder $USER
then log out and back in.
"""

import argparse
import json
import sys

sys.path.insert(0, "/home/efinder/Solver")
from maint import call as maint_call


def _print_result(resp):
    """Pretty-print a MaintResponse."""
    if not resp.ok:
        print(f"ERROR: {resp.error}", file=sys.stderr)
        return 1
    if resp.result is None:
        print("ok")
    elif isinstance(resp.result, dict):
        print(json.dumps(resp.result, indent=2, default=str, sort_keys=True))
    else:
        print(resp.result)
    return 0


def cmd_simple(name, args, parser):
    """Run a no-arg command and print the result."""
    return _print_result(maint_call(name))


def cmd_boresight(args, parser):
    if args.action == "show":
        return _print_result(maint_call("boresight_show"))
    if args.action == "center":
        return _print_result(maint_call("boresight_center"))
    if args.action == "set":
        if args.y is None or args.x is None:
            parser.error("boresight set requires Y and X")
        return _print_result(maint_call(
            "boresight_set", {"y": args.y, "x": args.x}))


def cmd_calibration(args, parser):
    if args.action == "status":
        return _print_result(maint_call("calibration_status"))
    if args.action == "reset":
        if not args.yes:
            ans = input("Reset FOV calibration and discard committed values? [y/N] ")
            if ans.strip().lower() not in ("y", "yes"):
                print("aborted")
                return 1
        return _print_result(maint_call("calibration_reset"))


def cmd_exposure(args, parser):
    if args.action == "get":
        return _print_result(maint_call("exposure_get"))
    if args.action == "set":
        if args.seconds is None:
            parser.error("exposure set requires SECONDS")
        return _print_result(maint_call(
            "exposure_set",
            {"exposure_s": args.seconds, "persist": args.persist}))


def cmd_gain(args, parser):
    if args.action == "set":
        if args.gain is None:
            parser.error("gain set requires GAIN")
        return _print_result(maint_call(
            "gain_set", {"gain": args.gain, "persist": args.persist}))


def cmd_polar(args, parser):
    if args.action == "start":
        return _print_result(maint_call("polar_start"))
    if args.action == "status":
        return _print_result(maint_call("polar_status"))
    if args.action == "cancel":
        return _print_result(maint_call("polar_cancel"))
    if args.action == "set-latitude":
        if args.latitude is None:
            parser.error("polar set-latitude requires LATITUDE in degrees")
        return _print_result(maint_call(
            "polar_set_latitude",
            {"latitude_deg": args.latitude,
             "persist": not args.no_persist}))


def cmd_raw(args, parser):
    try:
        obj = json.loads(args.json)
    except json.JSONDecodeError as e:
        parser.error(f"bad JSON: {e}")
    return _print_result(maint_call(
        cmd=obj.get("cmd", ""), args=obj.get("args") or {}))


def main():
    parser = argparse.ArgumentParser(
        description="Control and inspect a running eFinder daemon.")
    sub = parser.add_subparsers(dest="cmd", required=True)

    sub.add_parser("ping", help="Check the daemon is responsive")
    sub.add_parser("version", help="Show daemon version")
    sub.add_parser("status", help="Show current solution and config summary")

    p_bs = sub.add_parser("boresight", help="Manage the boresight pixel")
    p_bs.add_argument("action", choices=["show", "center", "set"])
    p_bs.add_argument("y", nargs="?", type=float, default=None)
    p_bs.add_argument("x", nargs="?", type=float, default=None)

    p_cal = sub.add_parser("calibration", help="Inspect or reset FOV calibration")
    p_cal.add_argument("action", choices=["status", "reset"])
    p_cal.add_argument("-y", "--yes", action="store_true",
                       help="Skip confirmation prompt for reset")

    p_exp = sub.add_parser("exposure", help="Read or change exposure")
    p_exp.add_argument("action", choices=["get", "set"])
    p_exp.add_argument("seconds", nargs="?", type=float, default=None)
    p_exp.add_argument("--persist", action="store_true",
                       help="Save the new value to eFinder.config")

    p_g = sub.add_parser("gain", help="Change camera gain")
    p_g.add_argument("action", choices=["set"])
    p_g.add_argument("gain", nargs="?", type=float, default=None)
    p_g.add_argument("--persist", action="store_true",
                     help="Save the new value to eFinder.config")

    p_pol = sub.add_parser("polar", help="Polar alignment workflow")
    p_pol.add_argument("action", choices=["start", "status", "cancel",
                                          "set-latitude"])
    p_pol.add_argument("latitude", nargs="?", type=float, default=None,
                       help="Latitude in degrees (for set-latitude)")
    p_pol.add_argument("--no-persist", action="store_true",
                       help="Don't write the latitude back to eFinder.config")

    p_raw = sub.add_parser("raw", help="Send a raw JSON request")
    p_raw.add_argument("json", help='e.g. \'{"cmd":"status","args":{}}\'")

    args = parser.parse_args()

    handlers = {
        "ping":        lambda a, p: cmd_simple("ping", a, p),
        "version":     lambda a, p: cmd_simple("version", a, p),
        "status":      lambda a, p: cmd_simple("status", a, p),
        "boresight":   cmd_boresight,
        "calibration": cmd_calibration,
        "exposure":    cmd_exposure,
        "gain":        cmd_gain,
        "polar":       cmd_polar,
        "raw":         cmd_raw,
    }
    try:
        return handlers[args.cmd](args, parser)
    except FileNotFoundError:
        print("ERROR: maintenance socket not found.\n"
              "Is the eFinder service running? Try:\n"
              "  systemctl status efinder",
              file=sys.stderr)
        return 2
    except PermissionError:
        print("ERROR: cannot access maintenance socket.\n"
              "Make sure you're in the 'efinder' group:\n"
              "  sudo usermod -a -G efinder $USER\n"
              "then log out and back in.",
              file=sys.stderr)
        return 2


if __name__ == "__main__":
    sys.exit(main() or 0)
