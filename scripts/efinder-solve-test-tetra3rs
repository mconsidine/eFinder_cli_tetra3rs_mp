#!/usr/bin/env python3
"""Standalone tetra3rs plate-solve diagnostic.

Usage:
    efinder-solve-test-tetra3rs IMAGE.png [--fov DEG] [--fov-err DEG]
                                          [--sigma SIGMA] [--timeout MS]
                                          [--max-centroids N] [--db PATH]

Loads IMAGE.png, extracts centroids via tetra3rs, and plate-solves.
Useful for tuning FOV/sigma settings without starting the full daemon.
"""
import argparse
import os
import sys
import time
from pathlib import Path

import numpy as np


def main():
    parser = argparse.ArgumentParser(description='tetra3rs plate-solve diagnostic')
    parser.add_argument('image', help='PNG image file to solve')
    parser.add_argument('--fov', type=float, default=11.0,
                        help='FOV estimate in degrees (default: 11.0)')
    parser.add_argument('--fov-err', type=float, default=1.0,
                        help='FOV max error in degrees (default: 1.0)')
    parser.add_argument('--sigma', type=float, default=10.0,
                        help='Centroid sigma threshold (default: 10.0)')
    parser.add_argument('--timeout', type=int, default=5000,
                        help='Solve timeout in ms (default: 5000)')
    parser.add_argument('--max-centroids', type=int, default=20,
                        help='Max centroids (default: 20)')
    parser.add_argument('--db', default=None,
                        help='Database path (default: ~/Solver/tetra3_index_1.6_0.4.bin)')
    args = parser.parse_args()

    try:
        from PIL import Image
    except ImportError:
        print('ERROR: Pillow not installed (pip install Pillow)', file=sys.stderr)
        sys.exit(1)
    try:
        import tetra3rs
    except ImportError:
        print('ERROR: tetra3rs not installed', file=sys.stderr)
        sys.exit(1)

    img_path = Path(args.image)
    if not img_path.exists():
        print('ERROR: image not found:', img_path, file=sys.stderr)
        sys.exit(1)

    db_path = args.db or str(Path.home() / 'Solver/tetra3_index_1.6_0.4.bin')
    if not os.path.exists(db_path):
        print('ERROR: database not found:', db_path, file=sys.stderr)
        print('Files in ~/Solver/:', list(Path.home().joinpath('Solver').glob('*.bin')),
              file=sys.stderr)
        sys.exit(1)

    print('Loading database:', db_path)
    db = tetra3rs.SolverDatabase.load_from_file(db_path)
    print('Database: stars=%d  patterns=%d  max_fov=%.1f°' % (
        db.num_stars, db.num_patterns, db.max_fov_deg))

    img = Image.open(img_path).convert('L')
    arr = np.array(img, dtype=np.uint8)
    h, w = arr.shape
    print('Image: %dx%d' % (w, h))

    print('Extracting centroids (sigma=%.1f, max=%d)...' % (args.sigma, args.max_centroids))
    t0 = time.time()
    ext = tetra3rs.extract_centroids(arr, sigma_threshold=args.sigma,
                                     max_centroids=args.max_centroids)
    t_extract = (time.time() - t0) * 1000
    n = len(ext.centroids)
    print('Centroids: %d found in %.1fms' % (n, t_extract))
    if n < 4:
        print('Too few centroids to solve (need >= 4)')
        sys.exit(1)

    print('Solving (fov=%.2f±%.2f°, timeout=%dms)...' % (args.fov, args.fov_err, args.timeout))
    t0 = time.time()
    sol = db.solve_from_centroids(
        ext.centroids,
        fov_estimate_deg=args.fov,
        fov_max_error_deg=args.fov_err,
        image_shape=(h, w),
        solve_timeout_ms=args.timeout,
    )
    t_solve = (time.time() - t0) * 1000

    if sol is None:
        print('No solution found (%.0fms)' % t_solve)
        sys.exit(1)

    ra_h = sol.ra_deg / 15.0
    hh = int(ra_h); mm = int((ra_h - hh) * 60); ss = int(((ra_h - hh) * 60 - mm) * 60)
    dec = sol.dec_deg
    sign = '+' if dec >= 0 else '-'
    dd = int(abs(dec)); dm = int((abs(dec) - dd) * 60)
    print('Solution (%.0fms):' % t_solve)
    print('  RA:  %02d:%02d:%02d' % (hh, mm, ss))
    print('  Dec: %s%02d*%02d' % (sign, dd, dm))
    print('  FOV: %.4f deg' % sol.fov_deg)
    try:
        print('  Roll: %.2f deg' % sol.roll_deg)
    except AttributeError:
        pass
    try:
        print('  Solve time: %.1fms' % sol.solve_time_ms)
    except AttributeError:
        pass


if __name__ == '__main__':
    main()
